{
    "name": "pixypuala/resilient-woocommerce-commerce-system",
    "description": "Resilient WooCommerce commerce system: idempotent webhook inbox, oversell-safe stock reservations, and integration contracts that protect revenue-critical workflows.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Pixypuala\\ResilientCommerce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pixypuala\\ResilientCommerce\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "lint:fix": "phpcbf"
    }
}
